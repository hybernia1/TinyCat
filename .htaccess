DirectoryIndex index.php

<FilesMatch "^(config(\.local)?\.php|composer\.(json|lock)|package(-lock)?\.json|.*\.sql)$">
    Require all denied
</FilesMatch>

RedirectMatch 404 ^/(App|lang|storage)(/|$)

<IfModule mod_setenvif.c>
    SetEnvIfNoCase Authorization "^(.+)$" HTTP_AUTHORIZATION=$1
    SetEnvIfNoCase Request_URI "\.(css|js|mjs|json|svg|png|jpe?g|gif|webp|ico|woff2?)$" tinycat_static_asset
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff" env=tinycat_static_asset
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteRule ^Public(/.*)?$ index.php [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
